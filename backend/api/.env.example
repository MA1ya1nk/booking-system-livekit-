DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hospital_booking
SECRET_KEY=change-me-super-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
# Same value as HOSPITAL_AGENT_API_KEY on the voice agent worker (header X-Agent-Key)
AGENT_API_KEY=generate-a-long-random-secret

# LiveKit (browser voice button — same project as your agent worker)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Same string as @server.rtc_session(agent_name="...")
LIVEKIT_AGENT_NAME=my-agent

# Resend (recommended on Render — set these and leave SMTP empty on the server)
RESEND_API_KEY=
# e.g. Booking <onboarding@resend.dev> or your verified domain sender
RESEND_FROM_EMAIL=

# SendGrid (optional fallback if Resend not set)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# SMTP (optional local/dev only; often fails from cloud hosts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# IANA timezone for all appointment wall times (DB stores naive local times in this zone)
APPOINTMENT_TIMEZONE=Asia/Kolkata

# Razorpay (test mode keys from https://dashboard.razorpay.com/app/keys — Key Id starts with rzp_test_)
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxxx
# Payment-link booking: Dashboard → Webhooks → https://YOUR_HOST/api/v1/payments/webhook — enable payment_link.paid (optional: payment.captured as fallback)
RAZORPAY_WEBHOOK_SECRET=whsec_xxxx
