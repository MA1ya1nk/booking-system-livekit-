DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hospital_booking
SECRET_KEY=change-me-super-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
# Same value as HOSPITAL_AGENT_API_KEY on the voice agent worker (header X-Agent-Key)
AGENT_API_KEY=generate-a-long-random-secret

# LiveKit (browser voice button — same project as your agent worker)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Same string as @server.rtc_session(agent_name="...")
LIVEKIT_AGENT_NAME=my-agent

# SendGrid email notifications (booking/cancellation)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# SMTP fallback notifications (works with Gmail/Outlook; for Gmail use App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# IANA timezone for all appointment wall times (DB stores naive local times in this zone)
APPOINTMENT_TIMEZONE=Asia/Kolkata
